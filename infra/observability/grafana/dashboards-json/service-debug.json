{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "russ360-service-debug",
  "title": "Service debug",
  "description": "Один сервис под лупой: выбери service/env вверху → RED-метрики, разбивка по роутам, и логи того же сериса с переходом в Explore. Рабочий процесс: всплеск на графике → смотри какой route → жми в логи.",
  "tags": ["russ360", "debug"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": { "query": "label_values(russ360_http_requests_total, service)", "refId": "svc" },
        "refresh": 2,
        "sort": 1,
        "current": { "text": "rusaifin", "value": "rusaifin" }
      },
      {
        "name": "env",
        "label": "env",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": { "query": "label_values(russ360_http_requests_total{service=\"$service\"}, env)", "refId": "env" },
        "refresh": 2,
        "sort": 1,
        "current": { "text": "prod", "value": "prod" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Запросов/сек",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(russ360_http_requests_total{service=\"$service\",env=\"$env\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "p95 латентность",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2.5 }] } }, "overrides": [] },
      "options": { "colorMode": "background" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(russ360_http_request_duration_seconds_bucket{service=\"$service\",env=\"$env\"}[5m])))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Доля 5xx",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }, "overrides": [] },
      "options": { "colorMode": "background" },
      "targets": [
        { "expr": "sum(rate(russ360_http_requests_total{service=\"$service\",env=\"$env\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(russ360_http_requests_total{service=\"$service\",env=\"$env\"}[5m])), 1e-9)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Исключений/мин",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } }, "overrides": [] },
      "options": { "colorMode": "background" },
      "targets": [
        { "expr": "sum(rate(russ360_exceptions_total{service=\"$service\",env=\"$env\"}[1m])) * 60", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Запросы по статус-кодам",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (status) (rate(russ360_http_requests_total{service=\"$service\",env=\"$env\"}[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 латентность во времени",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(russ360_http_request_duration_seconds_bucket{service=\"$service\",env=\"$env\"}[5m])))", "legendFormat": "p95", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(russ360_http_request_duration_seconds_bucket{service=\"$service\",env=\"$env\"}[5m])))", "legendFormat": "p50", "refId": "B" }
      ]
    },
    {
      "type": "table",
      "title": "Топ медленных роутов (p95, выбранный сервис)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum by (le,route) (rate(russ360_http_request_duration_seconds_bucket{service=\"$service\",env=\"$env\"}[5m]))))", "format": "table", "instant": true, "refId": "A" }
      ],
      "options": { "showHeader": true },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "p95 (s)" } } }
      ]
    },
    {
      "type": "table",
      "title": "Топ роутов с 4xx/5xx (req/s)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "topk(10, sum by (route,status) (rate(russ360_http_requests_total{service=\"$service\",env=\"$env\",status=~\"[45]..\"}[5m])))", "format": "table", "instant": true, "refId": "A" }
      ],
      "options": { "showHeader": true },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "req/s" } } }
      ]
    },
    {
      "type": "logs",
      "title": "Логи $service/$env (error/exception/critical) — клик по строке раскрывает поля, кнопка вверху панели ведёт в Explore",
      "id": 9,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        { "expr": "{service=\"$service\", env=\"$env\"} |~ \"(?i)error|exception|critical|fail\"", "refId": "A" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending", "enableLogDetails": true }
    }
  ]
}
