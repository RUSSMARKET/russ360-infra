# refresh-dev-from-prod — параметры подключения.
# Скопируй в refresh-dev-from-prod.env и заполни prod-секцию.
# Локальный блок уже выставлен по дефолтам — меняй только если у тебя нестандартный setup.

# ============================================================
# PROD (read-only) — заполни обязательно
# ============================================================

# SSH-доступ на прод-хост (используется только для pg_dump через docker exec)
PROD_SSH_HOST="82.146.57.149"
PROD_SSH_USER=""
# Пароль для sshpass; ИЛИ используй ключ — тогда оставь пустым и настрой ~/.ssh/config
PROD_SSH_PASSWORD=""

# Прод-MySQL (host MySQL на проде). Используется mysqldump через SSH.
# Если у тебя есть прямой сетевой доступ к проду по MySQL — пропиши хост напрямую и убери MYSQL_VIA_SSH=1.
MYSQL_VIA_SSH=1
PROD_MYSQL_HOST="127.0.0.1"
PROD_MYSQL_PORT="3306"
PROD_MYSQL_USER=""
PROD_MYSQL_PASSWORD=""

PROD_RUSAIFIN_DB="findatabase"

# rusaisklad на проде: "pg" или "mysql". Локально точно PG.
PROD_RUSAISKLAD_ENGINE="pg"
PROD_RUSAISKLAD_DB="rusaisklad"
PROD_RUSAISKLAD_DB_USER="rusaisklad"
PROD_RUSAISKLAD_PG_CONTAINER="rusaisklad_back-app-pgsql"   # пример, поправь

# Прод PostgreSQL — обычно живёт в docker-контейнере на проде.
# Если так — оставь PG_VIA_DOCKER=1 и пропиши имя контейнера на проде.
PG_VIA_DOCKER=1
PROD_RUSAIAUTH_PG_CONTAINER="rusaiauth-app-pgsql"   # пример, поправь
PROD_RUSAICORE_PG_CONTAINER="rusaicore-app-pgsql"   # пример, поправь

PROD_RUSAIAUTH_DB="auth"
PROD_RUSAIAUTH_DB_USER="auth"
PROD_RUSAICORE_DB="core"
PROD_RUSAICORE_DB_USER="core"

# ============================================================
# LOCAL (dev) — обычно править не нужно
# ============================================================

# Локальный host MySQL (по умолчанию из CLAUDE.md)
LOCAL_MYSQL_HOST="127.0.0.1"
LOCAL_MYSQL_PORT="3306"
LOCAL_MYSQL_USER="root"
LOCAL_MYSQL_PASSWORD=""
LOCAL_RUSAIFIN_DB="findatabase"

# Локальный rusaisklad PG в docker
LOCAL_RUSAISKLAD_PG_CONTAINER="rusaisklad_back_local-pgsql-1"
LOCAL_RUSAISKLAD_DB="rusaisklad"
LOCAL_RUSAISKLAD_DB_USER="rusaisklad"

# Локальные rusaiauth/rusaicore PG (пропиши свои имена контейнеров — у тебя они могут отличаться)
LOCAL_RUSAIAUTH_PG_CONTAINER="rusaiauth-pgsql"
LOCAL_RUSAIAUTH_DB="auth"
LOCAL_RUSAIAUTH_DB_USER="auth"

LOCAL_RUSAICORE_PG_CONTAINER="rusaicore-pgsql"
LOCAL_RUSAICORE_DB="core"
LOCAL_RUSAICORE_DB_USER="core"

# Имена контейнеров приложений (для php artisan db:anonymize)
LOCAL_RUSAIFIN_APP_CONTAINER="rusaifin_local-app-1"
LOCAL_RUSAISKLAD_APP_CONTAINER="rusaisklad_back_local-app-1"
LOCAL_RUSAIAUTH_APP_CONTAINER="rusaiauth-app"
LOCAL_RUSAICORE_APP_CONTAINER="rusaicore-app"
