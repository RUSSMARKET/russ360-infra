# Copy to .env and fill in.
# .env is gitignored.

# ---------- Grafana ----------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
GF_SERVER_ROOT_URL=http://localhost:3030
# Telegram alerting (Track B). Bot token is secret → set here. Chat id is NOT secret and is
# inlined in grafana/provisioning/alerting/contactpoints.yaml (edit it to the target chat id).
# Leave empty and Grafana still boots (placeholder default in compose); delivery just won't work.
GF_TELEGRAM_BOT_TOKEN=

# ---------- GlitchTip ----------
# 50+ char random string (e.g. `openssl rand -hex 32`)
GLITCHTIP_SECRET_KEY=changeme-must-be-50-chars-or-longer-random-string-here
GLITCHTIP_DB_PASSWORD=changeme
GLITCHTIP_DOMAIN=http://localhost:8050
# Local dev: consolemail prints emails to stdout. Prod: smtp://localhost:25
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_DEFAULT_FROM_EMAIL=glitchtip@localhost
# Set False once the first admin is created → закрывает форму signup для всех.
ENABLE_USER_REGISTRATION=True

# ---------- Promtail host bind sources ----------
# Локально пусто — оставляем /tmp/empty-* (создаются автоматом, см. README).
# На prod указывать на storage/logs rusaifin dev и prod.
RUSAIFIN_PROD_LOGS=/tmp/empty-prod
RUSAIFIN_DEV_LOGS=/tmp/empty-dev

# Где запущен стек (local|dev|prod). Подставляется в Promtail labels.
OBS_HOSTNAME=local
